---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { CATEGORIES } from '../../content/config';
import { CATEGORY_LABELS, CATEGORY_DESCRIPTIONS } from '../../lib/labels';

export const getStaticPaths = (async () => {
  const tools = await getCollection('tools');
  return CATEGORIES.map((category) => ({
    params: { category },
    props: {
      category,
      tools: tools
        .filter((t) => t.data.category === category)
        .sort((a, b) => a.data.title.localeCompare(b.data.title)),
    },
  }))
    // Only generate pages for categories that actually have tools.
    .filter((page) => page.props.tools.length > 0);
}) satisfies GetStaticPaths;

const { category, tools } = Astro.props;
const label = CATEGORY_LABELS[category];
const description = CATEGORY_DESCRIPTIONS[category];
---

<BaseLayout title={label} description={description}>
  <nav class="text-sm text-zinc-500">
    <a href="/browse" class="hover:text-accent">Browse</a>
    <span class="mx-2">/</span>
    <span>{label}</span>
  </nav>

  <h1 class="mt-3 text-3xl font-semibold tracking-tight">{label}</h1>
  <p class="mt-2 text-zinc-600 dark:text-zinc-400 max-w-2xl">{description}</p>
  <p class="mt-1 text-sm text-zinc-500">
    {tools.length} {tools.length === 1 ? 'tool' : 'tools'}
  </p>

  {
    tools.length > 0 ? (
      <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {tools.map((tool) => (
          <ToolCard tool={tool} />
        ))}
      </div>
    ) : (
      <p class="mt-8 text-zinc-500">No tools in this category yet.</p>
    )
  }
</BaseLayout>
