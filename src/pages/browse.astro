---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import FilterSidebar from '../components/FilterSidebar.astro';

const tools = await getCollection('tools');
const sorted = tools.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout
  title="Browse"
  description="Browse and filter the full catalog of Microsoft Fabric and Power BI developer tools."
>
  <div class="flex flex-col lg:flex-row gap-8">
    <FilterSidebar tools={sorted} />

    <!-- Main -->
    <div class="flex-1 min-w-0">
      <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
        <input
          type="search"
          id="search"
          placeholder="Search tools…"
          autocomplete="off"
          class="w-full sm:max-w-sm rounded-md bg-zinc-50 dark:bg-zinc-900 px-3 py-2 text-sm ring-1 ring-zinc-200 dark:ring-zinc-800 focus:ring-accent"
        />
        <div class="flex items-center gap-2 text-sm shrink-0">
          <label for="sort" class="text-zinc-500">Sort</label>
          <select
            id="sort"
            class="rounded-md bg-zinc-50 dark:bg-zinc-900 px-2 py-2 text-sm ring-1 ring-zinc-200 dark:ring-zinc-800 focus:ring-accent"
          >
            <option value="alpha">Alphabetical</option>
            <option value="recent">Recently added</option>
          </select>
        </div>
      </div>

      <p id="result-count" class="mt-4 text-sm text-zinc-500"></p>

      <div id="grid" class="mt-4 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {sorted.map((tool) => <ToolCard tool={tool} />)}
      </div>

      <p id="empty" class="mt-12 text-center text-zinc-500 hidden">
        No tools match your filters.
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const grid = document.getElementById('grid')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-tool]'));
  const search = document.getElementById('search') as HTMLInputElement;
  const sortSel = document.getElementById('sort') as HTMLSelectElement;
  const hideDep = document.getElementById('hide-deprecated') as HTMLInputElement;
  const filterInputs = Array.from(document.querySelectorAll<HTMLInputElement>('.filter'));
  const countEl = document.getElementById('result-count')!;
  const emptyEl = document.getElementById('empty')!;
  const GROUPS = ['category', 'type', 'pricing', 'source', 'maintainer'] as const;

  // Progressive enhancement: use Pagefind (full body-text search) when its
  // index is present (production build). In `dev` the import 404s and we fall
  // back to a client-side substring match over the rendered cards.
  let pagefind: any = null;
  let pfSlugs: Set<string> | null = null;

  (async () => {
    try {
      const path = '/pagefind/pagefind.js';
      pagefind = await import(/* @vite-ignore */ path);
      await pagefind.init();
      await update(); // re-run now that full-text search is available
    } catch {
      pagefind = null;
    }
  })();

  function slugFromUrl(u: string): string | null {
    const m = u.match(/\/tools\/([^/]+?)(?:\.html)?\/?$/);
    return m ? m[1] : null;
  }

  async function runPagefind(query: string) {
    if (!pagefind || !query) {
      pfSlugs = null;
      return;
    }
    try {
      const res = await pagefind.search(query);
      const datas = await Promise.all(res.results.map((r: any) => r.data()));
      pfSlugs = new Set(
        datas.map((d: any) => slugFromUrl(d.url)).filter((s): s is string => Boolean(s)),
      );
    } catch {
      pfSlugs = null;
    }
  }

  function checkedFor(group: string): Set<string> {
    return new Set(
      filterInputs.filter((i) => i.dataset.group === group && i.checked).map((i) => i.value),
    );
  }

  function matchesText(card: HTMLElement, q: string): boolean {
    if (!q) return true;
    if (pfSlugs) return pfSlugs.has(card.dataset.slug!);
    return card.dataset.search!.includes(q);
  }

  function apply() {
    const q = search.value.trim().toLowerCase();
    const checked: Record<string, Set<string>> = {};
    for (const g of GROUPS) checked[g] = checkedFor(g);

    let visible = 0;
    for (const card of cards) {
      const d = card.dataset;
      let show = true;
      if (hideDep.checked && d.deprecated === 'true') show = false;
      if (show && !matchesText(card, q)) show = false;
      if (show) {
        for (const g of GROUPS) {
          const set = checked[g];
          if (set.size && !set.has(d[g] as string)) {
            show = false;
            break;
          }
        }
      }
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    }

    countEl.textContent = `${visible} ${visible === 1 ? 'tool' : 'tools'}`;
    emptyEl.classList.toggle('hidden', visible !== 0);
    sortCards();
  }

  function sortCards() {
    const mode = sortSel.value;
    const shown = cards.filter((c) => !c.classList.contains('hidden'));
    shown.sort((a, b) =>
      mode === 'recent'
        ? Number(b.dataset.added) - Number(a.dataset.added)
        : a.dataset.title!.localeCompare(b.dataset.title!),
    );
    for (const c of shown) grid.appendChild(c);
  }

  async function update() {
    await runPagefind(search.value.trim());
    apply();
  }

  // Debounce text input (Pagefind queries are async).
  let timer: ReturnType<typeof setTimeout>;
  search.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(update, 140);
  });
  sortSel.addEventListener('change', sortCards);
  hideDep.addEventListener('change', apply);
  filterInputs.forEach((i) => i.addEventListener('change', apply));
  document.getElementById('clear-filters')!.addEventListener('click', () => {
    filterInputs.forEach((i) => (i.checked = false));
    hideDep.checked = true;
    search.value = '';
    update();
  });

  // Prefill from URL: ?q=, ?tag=, ?category=
  const params = new URLSearchParams(location.search);
  const q = params.get('q');
  const tag = params.get('tag');
  if (q) search.value = q;
  else if (tag) search.value = tag;
  const cat = params.get('category');
  if (cat) {
    const box = filterInputs.find((i) => i.dataset.group === 'category' && i.value === cat);
    if (box) box.checked = true;
  }

  update();
</script>
