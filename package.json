{
  "name": "fabricstack",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A curated catalog of tools, libraries, frameworks, and resources for Microsoft Fabric and Power BI developers.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "favicons": "node scripts/fetch-favicons.mjs",
    "og-image": "node scripts/generate-og.mjs",
