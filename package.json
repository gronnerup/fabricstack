    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.18.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "pagefind": "^1.5.2",
    "typescript": "^5.9.3"
  }
